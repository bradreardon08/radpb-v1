---
import flavors from '../data/flavors.json';
import '../styles/global.css';
---

<html lang="en">
	<head>
		<meta charset="utf-8" />
		<meta name="viewport" content="width=device-width" />
		<title>RAD Peanut Butter</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@700;900&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Montserrat:wght@700;800;900&display=swap" rel="stylesheet">
    <style>
      .flavorTag {
          -webkit-text-stroke: 4px #000000; 
          paint-order: stroke fill;
          
          filter: 
              drop-shadow(1px 1px 0px #000) 
              drop-shadow(2px 2px 0px #000) 
              drop-shadow(1px 0 0 #4dff00) 
              drop-shadow(-2px 0 0 #4dff00) 
              drop-shadow(0 2px 0 #4dff00) 
              drop-shadow(0 -2px 0 #4dff00)
              drop-shadow(1px 1px 0 #4dff00);

          @media (min-width: 768px) {
              filter: 
                drop-shadow(1px 1px 0px #000) 
                drop-shadow(2px 2px 0px #000) 
                drop-shadow(3px 3px 0px #000) 
                drop-shadow(4px 4px 0px #000) 
                drop-shadow(1px 0 0 #4dff00) 
                drop-shadow(-2px 0 0 #4dff00) 
                drop-shadow(0 2px 0 #4dff00) 
                drop-shadow(0 -2px 0 #4dff00)
                drop-shadow(1px 1px 0 #4dff00);
          }
      }

      .squiggle {
        position: relative;
      }
      .squiggle:after {
        content: url('/images/squiggle.png');
        position: absolute;
        left: calc(50% - 65px);
        bottom: -25px;
      }
    </style>
	</head>
	<body class="bg-[#0a0a0a] text-white font-['Montserrat'] overflow-x-hidden">
		
		<section class="h-screen flex flex-col justify-center items-center text-center p-6 border-b-8 border-[#4dff00]">
			<h1 class="font-['Montserrat'] font-black text-7xl md:text-[12rem] mb-4 tracking-tighter text-[#E83A92]">
				<img src="/images/rad_logo.png"/>
			</h1>
			<div class="squiggle mt-16 px-8 py-4 bg-[#4dff00] text-black font-black uppercase tracking-tighter">
				Store Opening Soon
			</div>
		</section>

		<main class="py-20">
			{flavors.map((flavor) => (
				<section class="reveal relative min-h-[60vh] flex flex-col md:flex-row items-center justify-center mb-24 last:mb-0 px-4 md:px-0">
					<div class="w-full md:w-3/5 overflow-hidden">
						<img 
							src={flavor.image} 
							alt={Array.isArray(flavor.name) ? flavor.name.join(' ') : flavor.name} 
							class="w-full h-auto object-cover shadow-2xl"
						/>
					</div>
					<div class="w-full md:w-2/5 p-8 md:p-20 flex flex-col justify-center">
						<h2 class="font-['Montserrat'] font-black text-5xl md:text-8xl uppercase mb-4 tracking-tighter leading-none flex flex-wrap gap-x-4">
              {Array.isArray(flavor.name) ? (
                  flavor.name.map((word, index) => (
                      <span class="flavorTag"
                          style={`
                              color: ${flavor.colors[index]}; 
                          `}
                      >
                          {word}
                      </span>
                  ))
              ) : (
                  <span class="flavorTag"
                      style={`
                          color: ${flavor.color}; 
                      `}
                  >
                      {flavor.name}
                  </span>
              )}
          </h2>
						<p class="text-lg md:text-2xl text-gray-400 font-medium leading-tight max-w-sm italic">
							{flavor.description}
						</p>
					</div>
				</section>
			))}
		</main>

		<footer class="p-12 text-center border-t-4 border-[#FF007F]">
			<p class="font-['Montserrat'] font-black text-2xl text-[#00FFFF]">Be RAD.</p>
			<p class="mt-2 text-sm text-gray-500 uppercase tracking-widest">© 2026 RAD Foods, LLC</p>
		</footer>

		<style>
			.reveal {
				opacity: 0;
				transform: translateY(100px);
				transition: all 1.2s cubic-bezier(0.17, 0.55, 0.55, 1);
			}
			.reveal.visible {
				opacity: 1;
				transform: translateY(0);
			}
		</style>

		<script>
			const observer = new IntersectionObserver((entries) => {
				entries.forEach(entry => {
					if (entry.isIntersecting) {
						entry.target.classList.add('visible');
					}
				});
			}, { threshold: 0.1 });

			document.querySelectorAll('.reveal').forEach(section => {
				observer.observe(section);
			});
		</script>
	</body>
</html>
		